<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <ScrollView
        android:id="@+id/scrollViewProfile"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- HEADER BANNER -->
            <ImageView
                android:id="@+id/imgBannerProfile"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:background="#1A1A1A"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- AVATAR -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgProfile"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_marginTop="120dp"
                android:background="#333333"
                android:padding="4dp"
                android:scaleType="centerCrop"
                app:strokeWidth="4dp"
                app:strokeColor="#00E676"
                app:shapeAppearanceOverlay="@style/CircleImageView"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- PLAYER OVR & POSITION (Mini Card) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="80dp"
                android:layout_marginTop="130dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/txtOvr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#00E676"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtPosicion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="#33FFFFFF"
                    android:paddingHorizontal="4dp" />
            </LinearLayout>

            <!-- PLAYER NAME & POSITION (NON-EDITABLE DISPLAY) -->
            <TextView
                android:id="@+id/txtDisplayName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Nombre Jugador"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/imgProfile"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/txtDisplayPosicion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Posición"
                android:textColor="#00E676"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="#1A00E676"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                app:layout_constraintTop_toBottomOf="@id/txtDisplayName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- EDITABLE FIELDS SECTION -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="30dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1A1A1A"
                app:layout_constraintTop_toBottomOf="@id/txtDisplayPosicion">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Información del Perfil"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/edtNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555555"
                        android:backgroundTint="#00E676"
                        android:inputType="textPersonName"/>

                    <EditText
                        android:id="@+id/edtApellido"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Apellido"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555555"
                        android:backgroundTint="#00E676"
                        android:inputType="textPersonName"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">
                        <EditText
                            android:id="@+id/edtAltura"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Altura (cm)"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555555"
                            android:backgroundTint="#00E676"
                            android:inputType="number"/>
                        <EditText
                            android:id="@+id/edtPeso"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Peso (kg)"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555555"
                            android:backgroundTint="#00E676"
                            android:inputType="number"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Posición de Juego"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp"/>

                    <Spinner
                        android:id="@+id/spinnerPosicion"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#00E676"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estilo de Juego"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="8dp"/>

                    <Spinner
                        android:id="@+id/spinnerTipoJuego"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#00E676"
                        android:popupBackground="#1A1A1A"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ACTION BUTTONS -->
            <Button
                android:id="@+id/btnActualizarPerfil"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="30dp"
                android:text="GUARDAR CAMBIOS"
                android:backgroundTint="#00E676"
                android:textColor="#000000"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/cardEdit" />

            <Button
                android:id="@+id/btnEliminarPerfil"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ELIMINAR MI CUENTA"
                android:textColor="#FF5252"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/btnActualizarPerfil"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- LOADING OVERLAY -->
            <FrameLayout
                android:id="@+id/loadingOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC0A0A0A"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="#00E676"/>
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabEditToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        app:srcCompat="@android:drawable/ic_menu_edit"
        app:backgroundTint="#00E676"
        app:tint="#000000" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
