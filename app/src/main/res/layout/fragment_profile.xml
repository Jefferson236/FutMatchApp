<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <ScrollView
        android:id="@+id/scrollViewProfile"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- HEADER BANNER -->
            <ImageView
                android:id="@+id/imgBannerProfile"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:background="#1A1A1A"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- PLAYER CARD (Merged from colleague's design) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/playerCard"
                android:layout_width="260dp"
                android:layout_height="300dp"
                android:layout_marginTop="30dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#FFE79A"
                app:cardElevation="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/txtOvr"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="44sp"
                                android:textStyle="bold"
                                android:textColor="#3A2A00" />

                            <TextView
                                android:id="@+id/txtPosicion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="---"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#3A2A00" />
                        </LinearLayout>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"/>

                        <FrameLayout
                            android:layout_width="90dp"
                            android:layout_height="90dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/imgProfile"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:scaleType="centerCrop"
                                app:shapeAppearanceOverlay="@style/CircleImageView"
                                android:contentDescription="Foto Jugador" />

                            <ImageView
                                android:id="@+id/btnEditPhoto"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="bottom|end"
                                android:background="#99000000"
                                android:padding="4dp"
                                android:src="@android:drawable/ic_menu_edit" />
                        </FrameLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtDisplayNameInCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="JUGADOR"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="#3A2A00"
                        android:layout_marginVertical="6dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#3A2A00"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginHorizontal="14dp">

                            <TextView
                                android:id="@+id/txtPac"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PAC --"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#3A2A00"/>

                            <TextView
                                android:id="@+id/txtSho"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SHO --"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#3A2A00"/>

                            <TextView
                                android:id="@+id/txtPas"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PAS --"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#3A2A00"/>
                        </LinearLayout>

                        <View
                            android:layout_width="2dp"
                            android:layout_height="55dp"
                            android:background="#3A2A00"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginHorizontal="14dp">

                            <TextView
                                android:id="@+id/txtDri"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DRI --"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#3A2A00"/>

                            <TextView
                                android:id="@+id/txtDef"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DEF --"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#3A2A00"/>

                            <TextView
                                android:id="@+id/txtPhy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PHY --"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#3A2A00"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- PLAYER NAME & POSITION (NON-EDITABLE DISPLAY) -->
            <TextView
                android:id="@+id/txtDisplayName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Nombre Jugador"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/playerCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/txtDisplayPosicion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Posición"
                android:textColor="#00E676"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="#1A00E676"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                app:layout_constraintTop_toBottomOf="@id/txtDisplayName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- EDITABLE FIELDS SECTION -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="30dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1A1A1A"
                app:layout_constraintTop_toBottomOf="@id/txtDisplayPosicion">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Información del Perfil"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/edtNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555555"
                        android:backgroundTint="#00E676"
                        android:inputType="textPersonName"/>

                    <EditText
                        android:id="@+id/edtApellido"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Apellido"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555555"
                        android:backgroundTint="#00E676"
                        android:inputType="textPersonName"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">
                        <EditText
                            android:id="@+id/edtAltura"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Altura (cm)"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555555"
                            android:backgroundTint="#00E676"
                            android:inputType="number"/>
                        <EditText
                            android:id="@+id/edtPeso"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Peso (kg)"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555555"
                            android:backgroundTint="#00E676"
                            android:inputType="number"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Posición de Juego"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp"/>

                    <Spinner
                        android:id="@+id/spinnerPosicion"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#00E676"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estilo de Juego"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="8dp"/>

                    <Spinner
                        android:id="@+id/spinnerTipoJuego"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#00E676"
                        android:popupBackground="#1A1A1A"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ACTION BUTTONS -->
            <Button
                android:id="@+id/btnActualizarPerfil"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="30dp"
                android:text="GUARDAR CAMBIOS"
                android:backgroundTint="#00E676"
                android:textColor="#000000"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/cardEdit" />

            <!-- GALLERY SECTION -->
            <TextView
                android:id="@+id/tvGalleryTitleProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mi Galería"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                app:layout_constraintTop_toBottomOf="@id/btnActualizarPerfil"
                app:layout_constraintStart_toStartOf="parent"/>

            <HorizontalScrollView
                android:id="@+id/scrollGalleryProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="20dp"
                app:layout_constraintTop_toBottomOf="@id/tvGalleryTitleProfile">
                <LinearLayout
                    android:id="@+id/galleryContainerProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="100dp"
                    android:orientation="horizontal">
                    <!-- Images will be added here -->
                    <ImageButton
                        android:id="@+id/btnAddPhotoProfile"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@android:drawable/ic_input_add"
                        android:background="#1A1A1A"
                        android:scaleType="centerInside"
                        android:tint="#00E676"
                        android:visibility="gone"/>
                </LinearLayout>
            </HorizontalScrollView>

            <Button
                android:id="@+id/btnEliminarPerfil"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ELIMINAR MI CUENTA"
                android:textColor="#FF5252"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/scrollGalleryProfile"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- LOADING OVERLAY -->
            <FrameLayout
                android:id="@+id/loadingOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC0A0A0A"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="#00E676"/>
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabEditToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        app:srcCompat="@android:drawable/ic_menu_edit"
        app:backgroundTint="#00E676"
        app:tint="#000000" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
