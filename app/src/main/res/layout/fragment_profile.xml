<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="260dp"
            android:layout_height="300dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="16dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#FFE79A"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/txtOvr"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="44sp"
                            android:textStyle="bold"
                            android:textColor="#3A2A00" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ED"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#3A2A00" />
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <FrameLayout
                        android:layout_width="90dp"
                        android:layout_height="90dp">

                        <ImageView
                            android:id="@+id/imgProfile"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:scaleType="centerCrop"
                            android:contentDescription="Foto Jugador" />

                        <ImageView
                            android:id="@+id/btnEditPhoto"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="bottom|end"
                            android:background="#99000000"
                            android:padding="4dp"
                            android:src="@android:drawable/ic_menu_edit" />
                    </FrameLayout>
                </LinearLayout>

                <EditText
                    android:id="@+id/edtPlayerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="HAZARD"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="#3A2A00"
                    android:background="@null"
                    android:layout_marginVertical="6dp"
                    android:inputType="textPersonName"
                    android:imeOptions="actionDone"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#3A2A00"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginHorizontal="14dp">

                        <TextView
                            android:id="@+id/txtPac"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#3A2A00"/>

                        <TextView
                            android:id="@+id/txtSho"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#3A2A00"/>

                        <TextView
                            android:id="@+id/txtPas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#3A2A00"/>
                    </LinearLayout>

                    <View
                        android:layout_width="2dp"
                        android:layout_height="55dp"
                        android:background="#3A2A00"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginHorizontal="14dp">

                        <TextView
                            android:id="@+id/txtDri"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#3A2A00"/>

                        <TextView
                            android:id="@+id/txtDef"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#3A2A00"/>

                        <TextView
                            android:id="@+id/txtPhy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#3A2A00"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calificación Post-Partido"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1E1E1E"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginVertical="12dp"/>

                <TextView
                    android:id="@+id/lblPace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ritmo (PAC): +0"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"/>

                <SeekBar
                    android:id="@+id/sliderPace"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:progress="0"
                    android:layout_marginVertical="8dp"/>

                <Button
                    android:id="@+id/btnSubmitReview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Guardar Valoración"
                    android:backgroundTint="#FFD700"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>