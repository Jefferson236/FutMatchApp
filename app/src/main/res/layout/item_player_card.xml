<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <ImageView
        android:id="@+id/ivPlayerPhoto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_background" />

    <View
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_black" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvPlayerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre Apellido"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProfileId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ID Perfil: #"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvPlayerStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OVR: 85 | PAC: 90 | SHO: 82"
            android:textColor="#00E676"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvPlayerInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="1.80m | 75kg | Delantero | Derecho"
            android:textColor="#CCCCCC"
            android:textSize="14sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivOverlayLike"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:src="@android:drawable/checkbox_on_background"
        android:visibility="gone"
        app:tint="#00E676" />

    <ImageView
        android:id="@+id/ivOverlayDislike"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:src="@android:drawable/ic_delete"
        android:visibility="gone"
        app:tint="#FF5252" />

</androidx.cardview.widget.CardView>