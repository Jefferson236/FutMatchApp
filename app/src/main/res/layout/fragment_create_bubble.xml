<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0A0A0A">

    <Spinner
        android:id="@+id/spinnerTipoJuegoBurbuja"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp" />

    <EditText
        android:id="@+id/etUbicacionBurbuja"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ubicación"
        android:textColor="#FFFFFF" />

    <EditText
        android:id="@+id/etFechaHoraBurbuja"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Fecha y Hora"
        android:textColor="#FFFFFF" />

    <EditText
        android:id="@+id/etCuotaBurbuja"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Cuota"
        android:inputType="numberDecimal"
        android:textColor="#FFFFFF" />

    <EditText
        android:id="@+id/etPosicionRequerida"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Posición Requerida"
        android:textColor="#FFFFFF" />

    <EditText
        android:id="@+id/etMensajeCapitan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mensaje del Capitán"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btnPublicarBurbuja"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Publicar" />

</LinearLayout>